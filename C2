function mBox(x,yB,z,w,h,d){return mul(T(x-w/2,yB,z-d/2),S(w,h,d));}
function mBoxRY(x,yB,z,w,h,d,ry){return mul(T(x,yB,z),mul(RY(ry),mul(T(-w/2,0,-d/2),S(w,h,d))));}
function mCyl(x,yB,z,r,h){return mul(T(x-r,yB,z-r),S(r*2,h,r*2));}
function mSph(x,y,z,r){return mul(T(x,y,z),S(r,r,r));}

// Wheel transform: X-axis cylinder placed at world position (wx,wy,wz)
// car right direction = (-sinA, 0, cosA), car forward = (cosA, 0, sinA)
// Column-major: col0=right*halfWidth*2, col1=up*radius, col2=forward*radius, col3=position
function wheelMat(wx,wy,wz,carA,radius,halfW){
  const ca=Math.cos(carA),sa=Math.sin(carA);
  const hw=halfW*2, r=radius;
  // right = (-sa, 0, ca), up=(0,1,0), fwd=(ca,0,sa)
  const m=new Float32Array(16);
  // col0 = right * hw
  m[0]=-sa*hw; m[1]=0;    m[2]=ca*hw;  m[3]=0;
  // col1 = up * r
  m[4]=0;      m[5]=r;    m[6]=0;      m[7]=0;
  // col2 = fwd * r
  m[8]=ca*r;   m[9]=0;    m[10]=sa*r;  m[11]=0;
  // col3 = position
  m[12]=wx;    m[13]=wy;  m[14]=wz;    m[15]=1;
  return m;}

function drawCar(x,y,z,ang,bodyTex,drawFn){
  const ca=Math.cos(ang),sa=Math.sin(ang);
  // Body
  const bW=3.5,bH=0.75,bD=2.0;
  const bodyM=mul(T(x,y+0.35,z),mul(RY(ang),mul(T(-bW/2,0,-bD/2),S(bW,bH,bD))));
  drawFn(GEO.box,bodyM,bodyTex,null,true);
  // Cabin
  const cabM=mul(T(x,y+0.35+bH,z),mul(RY(ang),mul(T(-0.7,0,-0.62),S(1.8,0.65,1.24))));
  drawFn(GEO.box,cabM,null,[0.06,0.14,0.30,1],false);
  // 4 wheels — car right = (-sa, 0, ca), car fwd = (ca, 0, sa)
  const wr=0.38, hw=0.28;
  // [fwd_offset, side_dir]: side_dir +1=right, -1=left
  [[1.05,1],[1.05,-1],[-1.05,1],[-1.05,-1]].forEach(([lf,ls])=>{
    const wx=x + ca*lf + (-sa)*ls*(0.95+hw);
    const wy=y + wr*0.48;
    const wz=z + sa*lf + ca*ls*(0.95+hw);
    drawFn(GEO.wheel, wheelMat(wx,wy,wz,ang,wr,hw), tWheel,null,false);
  });}

