    pos.push(cx,0,cz,cx,1,cz);nor.push(cx,0,cz,cx,0,cz);uv.push(i/segs,0,i/segs,1);}
  for(let i=0;i<segs;i++){const b=i*2;idx.push(b,b+2,b+1,b+1,b+2,b+3);}
  const tc=pos.length/3;pos.push(0,1,0);nor.push(0,1,0);uv.push(.5,.5);
  for(let i=0;i<=segs;i++){const a=i/segs*Math.PI*2;pos.push(Math.cos(a),1,Math.sin(a));nor.push(0,1,0);uv.push(.5+Math.cos(a)*.5,.5+Math.sin(a)*.5);}
  for(let i=0;i<segs;i++)idx.push(tc,tc+i+1,tc+i+2);
  const bc=pos.length/3;pos.push(0,0,0);nor.push(0,-1,0);uv.push(.5,.5);
  for(let i=0;i<=segs;i++){const a=i/segs*Math.PI*2;pos.push(Math.cos(a),0,Math.sin(a));nor.push(0,-1,0);uv.push(.5+Math.cos(a)*.5,.5+Math.sin(a)*.5);}
