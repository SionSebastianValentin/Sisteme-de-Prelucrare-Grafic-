    const a=i/la*Math.PI,b=j/lo*Math.PI*2,x=Math.sin(a)*Math.cos(b),y=Math.cos(a),z=Math.sin(a)*Math.sin(b);
    pos.push(x,y,z);nor.push(x,y,z);uv.push(j/lo,i/la);}
  for(let i=0;i<la;i++)for(let j=0;j<lo;j++){const a=i*(lo+1)+j;idx.push(a,a+lo+1,a+1,a+1,a+lo+1,a+lo+2);}
