  for(let i=0;i<segs;i++){const b=i*2;idx.push(b,b+1,b+3,b,b+3,b+2);}
  // Left cap
  const lc=pos.length/3;pos.push(-0.5,0,0);nor.push(-1,0,0);uv.push(.5,.5);
  for(let i=0;i<=segs;i++){const a=i/segs*Math.PI*2;pos.push(-0.5,Math.cos(a),Math.sin(a));nor.push(-1,0,0);uv.push(.5+Math.cos(a)*.5,.5+Math.sin(a)*.5);}
  for(let i=0;i<segs;i++)idx.push(lc,lc+i+2,lc+i+1);
  // Right cap
  const rc=pos.length/3;pos.push(0.5,0,0);nor.push(1,0,0);uv.push(.5,.5);
  for(let i=0;i<=segs;i++){const a=i/segs*Math.PI*2;pos.push(0.5,Math.cos(a),Math.sin(a));nor.push(1,0,0);uv.push(.5+Math.cos(a)*.5,.5+Math.sin(a)*.5);}
  for(let i=0;i<segs;i++)idx.push(rc,rc+i+1,rc+i+2);
