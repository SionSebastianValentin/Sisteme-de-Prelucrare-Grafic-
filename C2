    drawFn(GEO.box,mBox(g.x,g.h,g.z-3,g.w+2,1,g.d+6),tRoof,null,true);
    for(let i=0;i<5;i++){const cx=g.x-g.w/2+i*(g.w/4)+.5;
      drawFn(GEO.cyl,mCyl(cx,0,g.z-g.d/2,.38,g.h),tConc,null,true);}
    drawFn(GEO.box,mBox(g.x,g.h+1,g.z,g.w*.35,3,g.d*.3),tBldB,null,true);}
  for(let i=0;i<16;i++){const a=(i+.5)/16*Math.PI*2;
    drawFn(GEO.box,mBoxRY(Math.cos(a)*53.5,.05,Math.sin(a)*36,3,.55,.45,a+Math.PI/2),tConc,null,true);}
  drawCar(car.x,car.y,car.z,car.angle,tCar,drawFn);
  NPC.forEach(n=>{const p=ovalPos(n.t);drawCar(p.x,0,p.z,p.ang,n.tex,drawFn);});
  PEDS.forEach(p=>drawPed(p,drawFn));}

// ── LAMP POST SHADOW QUADS (analytical) ──────────────────────
// Given sun direction (sx,sy,sz) normalized, a vertical pole at (px,pz) height H,
// the shadow on the ground is a line from the pole base extending opposite the sun.
// We render it as a thin quad.
function drawLampShadows(sunDir,lampIntensity){
  if(!document.getElementById('lsEn').checked)return;
  const [sx,sy,sz]=sunDir;
  if(sy<0.04)return; // don't draw at night/dusk extremes
  // shadow length = H/tan(elevation) = H*horiz/sy
  const horiz=Math.sqrt(sx*sx+sz*sz);
  if(horiz<0.001)return;
  const sLen=LAMP_H/sy*horiz; // length of shadow on ground
  // Shadow goes in direction opposite to sun's XZ component, normalized
  const sdx=-sx/horiz, sdz=-sz/horiz;
  // Pole radius = 0.14, shadow half-width on ground = lampRadius/sy * horiz ≈ thin
  const hw=0.18; // half width of shadow quad
  // perpendicular to shadow direction
  const px2=-sdz, pz2=sdx;
  const alpha=Math.min(0.6, sy*1.2)*lampIntensity;
  gl.useProgram(pFlat);
  gl.enable(gl.BLEND);
  gl.blendFunc(gl.SRC_ALPHA,gl.ONE_MINUS_SRC_ALPHA);
  gl.depthMask(false);
  LAMPS.forEach(([lx,lz])=>{
    // 4 verts of shadow quad: base corners + tip corners
    const bx0=lx+px2*hw, bz0=lz+pz2*hw;
    const bx1=lx-px2*hw, bz1=lz-pz2*hw;
    const tx0=lx+sdx*sLen+px2*hw*0.2, tz0=lz+sdz*sLen+pz2*hw*0.2;
    const tx1=lx+sdx*sLen-px2*hw*0.2, tz1=lz+sdz*sLen-pz2*hw*0.2;
    const verts=new Float32Array([bx0,0.01,bz0, bx1,0.01,bz1, tx1,0.01,tz1, tx0,0.01,tz0]);
    gl.bindBuffer(gl.ARRAY_BUFFER,shadowQuadBuf);
    gl.bufferData(gl.ARRAY_BUFFER,verts,gl.DYNAMIC_DRAW);
    const lP=gl.getAttribLocation(pFlat,'aP');
    gl.enableVertexAttribArray(lP);gl.vertexAttribPointer(lP,3,gl.FLOAT,false,0,0);
    gl.uniformMatrix4fv(gl.getUniformLocation(pFlat,'uMVP'),false,CVP);
    gl.uniform1f(gl.getUniformLocation(pFlat,'uAlpha'),alpha);
    gl.bindBuffer(gl.ELEMENT_ARRAY_BUFFER,shadowQuadIdx);
    gl.drawElements(gl.TRIANGLES,6,gl.UNSIGNED_SHORT,0);
  });
  gl.depthMask(true);
  gl.disable(gl.BLEND);}

// ── CAMERA ────────────────────────────────────────────────────
let camX=0,camY=70,camZ=105,yaw=0,pitch=-.48;
let md=false,mx=0,my=0;
const keys={};
cv.addEventListener('mousedown',e=>{md=true;mx=e.clientX;my=e.clientY;});
cv.addEventListener('mouseup',()=>md=false);
cv.addEventListener('mousemove',e=>{if(!md)return;yaw+=(e.clientX-mx)*.004;pitch+=(e.clientY-my)*.004;pitch=Math.max(-1.4,Math.min(.25,pitch));mx=e.clientX;my=e.clientY;});
cv.addEventListener('wheel',e=>{const f=fwdC(),s=e.deltaY*.09;camX+=f[0]*s;camY+=f[1]*s;camZ+=f[2]*s;camY=Math.max(1,camY);},{passive:true});
document.addEventListener('keydown',e=>{keys[e.key]=true;if(e.key.startsWith('Arrow'))e.preventDefault();});
document.addEventListener('keyup',e=>keys[e.key]=false);
function fwdC(){return[Math.sin(yaw)*Math.cos(pitch),-Math.sin(pitch),-Math.cos(yaw)*Math.cos(pitch)];}
function rgtC(){return[Math.cos(yaw),0,Math.sin(yaw)];}

const todEl=document.getElementById('tod'),todLbl=document.getElementById('todLbl');
const shEn=document.getElementById('shEn'),lpEn=document.getElementById('lpEn');
todEl.addEventListener('input',()=>{const v=+todEl.value,h=~~v,mn=~~((v-h)*60);
  todLbl.textContent=`${String(h).padStart(2,'0')}:${String(mn).padStart(2,'0')}`;});
let PROJ=persp(Math.PI/3,cv.width/cv.height,.2,700);

function sunUpdate(tod){
  const t=(tod-6)/16, a=t*Math.PI;
  const sx=-.3*Math.cos(a), sy=Math.max(.04,Math.sin(a)*.95+.04), sz=-.2;
  const l=Math.sqrt(sx*sx+sy*sy+sz*sz);
  const snx=sx/l,sny=sy/l,snz=sz/l;
  // Tight ortho: 85 units covers the whole circuit + buildings
  LVP=mul(ortho(-85,85,-85,85,.5,300),lookAt(snx*150,sny*150,snz*150,0,0,0));
  return[snx,sny,snz];}

function frame(){
  const sp=.28,f=fwdC(),r=rgtC();
  if(keys['w']||keys['W']){camX+=f[0]*sp;camY+=f[1]*sp;camZ+=f[2]*sp;}
  if(keys['s']||keys['S']){camX-=f[0]*sp;camY-=f[1]*sp;camZ-=f[2]*sp;}
  if(keys['a']||keys['A']){camX-=r[0]*sp;camZ-=r[2]*sp;}
  if(keys['d']||keys['D']){camX+=r[0]*sp;camZ+=r[2]*sp;}
  if(keys['q']||keys['Q'])camY-=sp;if(keys['e']||keys['E'])camY+=sp;
  camY=Math.max(1,camY);

  if(keys['ArrowUp'])   car.speed=Math.min(car.speed+car.accel,car.maxSpeed);
  else if(keys['ArrowDown'])car.speed=Math.max(car.speed-car.brake,-car.maxSpeed*.35);
  else car.speed*=car.friction;
  if(Math.abs(car.speed)>0.002){
    const d=car.speed>0?1:-1;
    if(keys['ArrowLeft'])car.angle-=car.turn*d;
    if(keys['ArrowRight'])car.angle+=car.turn*d;}
  if(car.cd>0)car.cd--;
  const nx=car.x+Math.cos(car.angle)*car.speed, nz=car.z+Math.sin(car.angle)*car.speed;
  if(carHit(nx,nz)){
    if(car.cd===0){colCount++;document.getElementById('col').textContent=colCount;car.cd=45;colTimer=70;}
    car.speed*=-.4;
  }else{car.x=nx;car.z=nz;}
  const cm=document.getElementById('cmsg');
  if(colTimer>0){cm.style.display='block';cm.style.opacity=(--colTimer/15).toString();}else cm.style.display='none';
  document.getElementById('spd').textContent=Math.abs(~~(car.speed*200));

  NPC.forEach(n=>n.t=(n.t+n.sp)%1);
  updatePeds();

  const tod=+todEl.value, sd=sunUpdate(tod);
  const t=(tod-6)/16, br=Math.max(0,Math.sin(t*Math.PI));
  const warm=Math.max(0,1-Math.abs(t-.12)*10)+Math.max(0,1-Math.abs(t-.88)*10);
  const f2=fwdC();
  CVP=mul(PROJ,lookAt(camX,camY,camZ,camX+f2[0],camY+f2[1],camZ+f2[2]));

  // ── SHADOW PASS ──
  gl.bindFramebuffer(gl.FRAMEBUFFER,SFB);
  gl.viewport(0,0,SS,SS);gl.clearColor(1,1,1,1);gl.clear(gl.COLOR_BUFFER_BIT|gl.DEPTH_BUFFER_BIT);
  gl.useProgram(pSh);drawScene(ds);

  // ── MAIN PASS ──
  gl.bindFramebuffer(gl.FRAMEBUFFER,null);
  gl.viewport(0,0,cv.width,cv.height);
  gl.clearColor(.55,.78,1,1);gl.clear(gl.COLOR_BUFFER_BIT|gl.DEPTH_BUFFER_BIT);

  // Sky
  gl.useProgram(pSky);gl.depthMask(false);
  const sv=new Float32Array(lookAt(camX,camY,camZ,camX+f2[0],camY+f2[1],camZ+f2[2]));
  sv[12]=0;sv[13]=0;sv[14]=0;
  gl.uniformMatrix4fv(gl.getUniformLocation(pSky,'uVP'),false,mul(PROJ,sv));
  gl.uniform1f(gl.getUniformLocation(pSky,'uT'),tod);
  ba(pSky,'aP',GEO.sky.pos,3);
  gl.bindBuffer(gl.ELEMENT_ARRAY_BUFFER,GEO.sky.idx);
  gl.drawElements(gl.TRIANGLES,GEO.sky.cnt,gl.UNSIGNED_SHORT,0);
  gl.depthMask(true);

  // Scene
  gl.useProgram(pM);
  gl.uniform3fv(gl.getUniformLocation(pM,'uSD'),sd);
  gl.uniform3fv(gl.getUniformLocation(pM,'uSC'),[br*(1+warm*.2),br*(.86+warm*.04),br*(.66-warm*.18)]);
  gl.uniform3fv(gl.getUniformLocation(pM,'uAC'),[.14+br*.22,.14+br*.17,.18+br*.12]);
  gl.activeTexture(gl.TEXTURE1);gl.bindTexture(gl.TEXTURE_2D,STEX);
  gl.uniform1i(gl.getUniformLocation(pM,'uSM'),1);
  gl.uniform1f(gl.getUniformLocation(pM,'uSMRes'),1/SS);
  gl.uniform1i(gl.getUniformLocation(pM,'uSE'),shEn.checked?1:0);
  gl.uniform1i(gl.getUniformLocation(pM,'uLE'),lpEn.checked?1:0);
  gl.uniform1i(gl.getUniformLocation(pM,'uLN'),LAMPS.length);
  const lp=[],lc=[];
  LAMPS.forEach(([px,pz])=>{lp.push(px,LAMP_H,pz);lc.push(1,.88,.5);});
  gl.uniform3fv(gl.getUniformLocation(pM,'uLP'),lp);
  gl.uniform3fv(gl.getUniformLocation(pM,'uLC'),lc);
  drawScene(dm);

  // Analytical lamp post shadows on top (blended quads)
  drawLampShadows(sd, br);

  requestAnimationFrame(frame);}

window.addEventListener('resize',()=>{cv.width=innerWidth;cv.height=innerHeight;PROJ=persp(Math.PI/3,cv.width/cv.height,.2,700);});
frame();
</script>
